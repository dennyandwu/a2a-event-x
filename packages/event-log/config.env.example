# Shared Event Log environment (source this or export before a2ax-web / a2a-v2)
# cp packages/event-log/config.env.example ~/.a2a-event-x/event-log.env

# State root (JSONL + sqlite live under here historically)
export A2A_LOG_HOME="${A2A_LOG_HOME:-$HOME/.openclaw/workspace/state/a2a-log}"

# Optional explicit v2 DB path
# export A2A_V2_DB="$A2A_LOG_HOME/db/a2a-v2.sqlite"

# Canonical v1 CLI (default: monorepo packages/event-log/scripts/a2a-log.py)
# export A2A_LOG_CLI="/path/to/a2a-event-x/packages/event-log/scripts/a2a-log.py"

# Web bind
# export A2AX_HOST=127.0.0.1
# export A2AX_PORT=8787

# Live data without A2AX_AUTHORITY → auto readonly (safe for laptop mirrors).
# export A2AX_READONLY=1          # force readonly
# export A2AX_READONLY=0          # force write (not recommended on mirror)
# export A2AX_AUTHORITY=1         # write mode (Mac Mini / authoritative host)

# Optional API token
# export A2AX_TOKEN=...

# Stale threshold hours for freshness banner (default 24)
# export A2AX_STALE_HOURS=24

# rsync source for npm run sync:log
# export A2AX_SYNC_REMOTE='macmini-ts:~/.openclaw/workspace/state/a2a-log/'
